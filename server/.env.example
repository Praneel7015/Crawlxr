PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/crawlerdb
RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY
PRIVATE_KEY=YOUR_SERVER_WALLET_PRIVATE_KEY
CRAWLER_CONTRACT_ADDRESS=0xYourDeployedContractAddress
REQUIRE_NODE_REGISTRATION=true
CRAWLER_NODE_ID=node-1
ALLOWED_ORIGIN=http://localhost:5173

# Dynamic link extraction fallback (Playwright)
BROWSER_CRAWL_ENABLED=true
CRAWL_STATIC_TIMEOUT_MS=30000
CRAWL_BROWSER_TIMEOUT_MS=45000
CRAWL_BROWSER_WAIT_MS=6000
CRAWL_MAX_LINKS=100
